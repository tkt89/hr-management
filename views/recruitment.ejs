<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HR System - Recruitment</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('_header') %>

    <main class="dashboard">
      <section class="hero-card">
        <div>
          <p class="eyebrow">Hiring</p>
          <h2>Recruitment pipeline</h2>
        </div>
        <button class="primary-btn">Post job</button>
      </section>

      <section class="stats-grid">
        <article class="stat-card">
          <p>Open positions</p>
          <h3>5</h3>
          <span class="trend">2 urgent</span>
        </article>
        <article class="stat-card">
          <p>Interviewing</p>
          <h3>3</h3>
          <span class="trend">This week</span>
        </article>
        <article class="stat-card">
          <p>Offers sent</p>
          <h3>1</h3>
          <span class="trend">1 accepted</span>
        </article>
        <article class="stat-card">
          <p>Candidate pool</p>
          <h3>12</h3>
          <span class="trend">Ready to review</span>
        </article>
      </section>

      <section class="content-grid">
        <article class="panel panel-large">
          <div class="panel-header">
            <div>
              <p class="eyebrow">Candidates</p>
              <h3>Recent applicants</h3>
            </div>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Applied</th>
                  <th>Status</th>
                  <th>Recruiter</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Ian Wright</td>
                  <td>2026-05-10</td>
                  <td><span class="pill active">Hired</span></td>
                  <td>David Miller</td>
                </tr>
                <tr>
                  <td>Julia Roberts</td>
                  <td>2026-05-28</td>
                  <td><span class="pill">Pending</span></td>
                  <td>David Miller</td>
                </tr>
              </tbody>
            </table>
          </div>
        </article>

        <article class="panel">
          <div class="panel-header">
            <div>
              <p class="eyebrow">Pipeline</p>
              <h3>Stages</h3>
            </div>
          </div>
          <div class="attendance-stack">
            <div><span>Sourced</span><strong>8</strong></div>
            <div><span>Interview</span><strong>3</strong></div>
            <div><span>Offer</span><strong>1</strong></div>
          </div>
        </article>
      </section>
    </main>
  </body>
</html>
